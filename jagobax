#include <ESP8266WiFi.h> // WiFi library for ESP8266

// WiFi  configuration
const char* ssid = "5TALDEA";    // OLP
const char* password = "SANJACOBO";   // oteitzaLP

// Funtzioak
void setup_wifi() {
  delay(10);
  Serial.println();
  Serial.print("Wifi-ra konektatzen: ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("");
  Serial.println("WiFira konektatua !!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
}

void setup() {
  Serial.begin(9600);
  setup_wifi();
}

void loop() {
}

